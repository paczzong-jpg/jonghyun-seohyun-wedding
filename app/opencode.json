{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["INSTRUCTIONS.md", ".miso/rules/**/*.md", ".miso/specs/**/*.md"],
  "permission": {
    "edit": {
      "*": "allow",
      "api/_runtime_proxy.js": "deny",
      "src/lib/miso-sdk/**": "deny",
      "src/lib/miso-sdk/*": "deny",
      "src/components/ui/**": "deny",
      "src/components/ui/*": "deny",
      ".npmrc": "deny",
      "pnpm-lock.yaml": "deny",
      "pnpm-workspace.yaml": "deny",
      "vite.config.ts": "deny",
      "opencode.json": "deny",
      "INSTRUCTIONS.md": "deny",
      ".miso/bin/**": "deny",
      ".miso/bin/*": "deny",
      ".miso/specs/**": "deny",
      ".miso/specs/*": "deny",
      ".miso/rules/**": "deny",
      ".miso/rules/*": "deny",
      ".miso/NOTICE.md": "deny",
      ".miso/LICENSES/**": "deny",
      ".miso/LICENSES/*": "deny",
      ".miso/skills/**": "deny",
      ".miso/skills/*": "deny",
      ".miso/agents/**": "deny",
      ".miso/agents/*": "deny",
      "/workspace/.pocketbase/**": "deny",
      "src/lib/miso-client.ts": "deny",
      ".env": "ask"
    },
    "bash": {
      "*": "allow",
      "kill *": "deny",
      "pkill *": "deny",
      "killall *": "deny",
      "skill *": "deny",
      "lsof *": "deny",
      "fuser *": "deny",
      "ss *": "deny",
      "netstat *": "deny",
      "*pnpm-lock.yaml*": "deny",
      "sh *": "deny",
      "bash *": "deny",
      "zsh *": "deny",
      "dash *": "deny",
      "fish *": "deny",
      "node -e *": "deny",
      "node --eval *": "deny",
      "node -p *": "deny",
      "python -c *": "deny",
      "python3 -c *": "deny",
      "perl -e *": "deny",
      "ruby -e *": "deny",
      "vite *": "deny",
      "npx vite*": "deny",
      "npm run dev*": "deny",
      "pnpm dev*": "deny",
      "pnpm run dev*": "deny",
      "yarn dev*": "deny",
      "yarn run dev*": "deny",
      "bun dev*": "deny",
      "bun run dev*": "deny",
      "npm start*": "deny",
      "rm -rf .miso*": "deny",
      "rm -rf /workspace/.miso*": "deny"
    },
    "read": {
      "*": "allow",
      "*.pdf": "deny",
      "*.doc": "deny",
      "*.docx": "deny",
      "*.ppt": "deny",
      "*.pptx": "deny",
      "*.xls": "deny",
      "*.xlsx": "deny",
      "*.hwp": "deny",
      "*.hwpx": "deny",
      "*.odt": "deny",
      "*.ods": "deny",
      "*.odp": "deny",
      "*.pages": "deny",
      "*.numbers": "deny",
      "*.key": "deny",
      "*.png": "deny",
      "*.jpg": "deny",
      "*.jpeg": "deny",
      "*.gif": "deny",
      "*.webp": "deny",
      "*.ico": "deny",
      "*.bmp": "deny",
      "*.tif": "deny",
      "*.tiff": "deny",
      "*.avif": "deny",
      "*.heic": "deny",
      "*.mp3": "deny",
      "*.wav": "deny",
      "*.m4a": "deny",
      "*.flac": "deny",
      "*.ogg": "deny",
      "*.mp4": "deny",
      "*.mov": "deny",
      "*.avi": "deny",
      "*.mkv": "deny",
      "*.webm": "deny",
      "*.zip": "deny",
      "*.rar": "deny",
      "*.7z": "deny",
      "*.tar": "deny",
      "*.gz": "deny",
      "*.tgz": "deny",
      "*.bz2": "deny",
      "*.xz": "deny"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "external_directory": {
      "*": "deny",
      "/tmp": "allow",
      "/tmp/**": "allow",
      "/opt/miso": "allow",
      "/opt/miso/**": "allow",
      "/workspace/.pocketbase/prod/runtime_state": "allow",
      "/workspace/.pocketbase/prod/runtime_state/**": "allow"
    }
  }
}
