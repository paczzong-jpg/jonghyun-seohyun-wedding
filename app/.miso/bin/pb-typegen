#!/bin/sh
# PlaiMaker Coder — PocketBase 컬렉션 → TypeScript 타입 자동 생성
# 사용법: .miso/bin/pb-typegen
# 결과: src/types/pb-types.ts
set -e

SM_URL="${SM_INTERNAL_URL}"
APP_ID="${RUNTIME_APP_ID}"

if [ -z "$SM_URL" ] || [ -z "$APP_ID" ]; then
  echo "Error: SM_INTERNAL_URL and RUNTIME_APP_ID must be set" >&2
  exit 1
fi

BASE="${SM_URL}/internal/coder/runtime/${APP_ID}/data/api"

# Fetch collections list
if ! COLLECTIONS=$(curl -fsS "${BASE}/collections"); then
  echo "Error: Failed to fetch collections from PocketBase" >&2
  exit 1
fi

# Output directory
mkdir -p src/types

# Generate TypeScript file
OUTPUT="src/types/pb-types.ts"
cat > "$OUTPUT" << 'HEADER'
// Auto-generated by pb-typegen — DO NOT EDIT MANUALLY
// Regenerate: .miso/bin/pb-typegen

/** PocketBase 레코드 공통 필드 */
export interface BaseRecord {
  id: string;
  created: string;
  updated: string;
  collectionId: string;
  collectionName: string;
}

HEADER

# Parse collections and generate interfaces using node (available in sandbox)
node -e "
const data = JSON.parse(process.argv[1]);
const items = data.items || data || [];

const typeMap = {
  text: 'string',
  email: 'string',
  url: 'string',
  editor: 'string',
  number: 'number',
  bool: 'boolean',
  date: 'string',
  autodate: 'string',
  select: 'string',
  relation: 'string',
  file: 'string',
  json: 'unknown',
  password: 'string',
};

function pascalCase(str) {
  return str.replace(/(^|[_-])([a-z])/g, (_, __, c) => c.toUpperCase());
}

for (const col of items) {
  if (col.name.startsWith('_')) continue; // Skip system collections
  const name = pascalCase(col.name) + 'Record';
  const fields = (col.fields || col.schema || [])
    .filter(f => !['id','created','updated','collectionId','collectionName'].includes(f.name))
    .map(f => {
      const tsType = typeMap[f.type] || 'unknown';
      const optional = f.required ? '' : '?';
      return '  ' + f.name + optional + ': ' + tsType + ';';
    });
  console.log('export interface ' + name + ' extends BaseRecord {');
  if (fields.length > 0) {
    console.log(fields.join('\n'));
  }
  console.log('}');
  console.log('');
}
" "$COLLECTIONS"  >> "$OUTPUT"

echo "Generated: ${OUTPUT}"
